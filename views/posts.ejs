<!DOCTYPE html>

<html>

<head>
    <title>CampusConnect</title>
<script>
    function toggleEdit(id) {

        const form =
            document.getElementById(
                "editForm-" + id
            );

        if (form.style.display === "none") {

            form.style.display = "block";

        } else {

            form.style.display = "none";

        }
    }
</script>
</head>
<body>
```
<div class="card shadow-lg border-0 mb-4">
    <div class="card-body p-4">

        <h2 class="fw-bold">
            Welcome Back,
            <%= currentUser.username %> 👋
        </h2>

        <p class="text-muted mb-0">
            Connect • Collaborate • Learn • Grow
        </p>

    </div>
</div>

<div class="card shadow-sm border-0 mb-4">

    <div class="card-body">

        <form action="/posts" method="GET">

            <div class="input-group">

                <input
                type="text"
                name="search"
                value="<%= search %>"
                class="form-control form-control-lg"
                placeholder="Search students, posts, ideas...">

                <button
                class="btn btn-primary">

                🔍 Search

                </button>

            </div>

        </form>

    </div>

</div>

<% if(currentUser && currentUser.isAdmin){ %>

    <a
        href="/admin"
        class="btn btn-danger mb-3">

        ⚙ Admin Panel

    </a>

<% } %>

<% if(posts.length===0){ %>

    <div class="alert alert-info">

        No Posts Yet 🚀

    </div>

<% } %>

<% posts.forEach(post=>{ %>

    <div class="card post-card shadow-lg mb-4">
        <div class="card-body">

            <div class="d-flex justify-content-between">

                <div>

                    <h5 class="mb-0">

                        <a
                            href="/user/<%= post.author._id %>"
                            class="text-decoration-none">

                            <%= post.author.username %>

                        </a>

                    </h5>

                    <small class="text-muted">

                        <%= post.createdAt.toLocaleString() %>

                    </small>

                </div>

            </div>

            <hr>

            <h3 class="fw-bold mb-3"><%= post.title %></h3>
            <p class="fs-5 text-secondary"> <%= post.content %></p>
            <% if(post.fileUrl){ %>

                <% if(post.fileType.startsWith("image")){ %>

                    <img src="<%= post.fileUrl %>" class="post-image shadow ">
                <% }else{ %>

                    <a
                        href="<%= post.fileUrl %>"
                        target="_blank"
                        class="btn btn-primary mb-3">

                        📄 Open PDF

                    </a>

                <% } %>

            <% } %>

            <div class="mb-3">

                <span class="badge bg-primary">

                    Followers:
                    <%= post.author.followers ? post.author.followers.length : 0 %>

                </span>

            </div>

            <% if(post.author &&
            post.author._id.toString() !==
            currentUserId.toString()){ %>

                <form
                    action="/follow/<%= post.author._id %>"
                    method="POST"
                    class="mb-3">

                    <button
                        class="btn btn-sm <%= currentUser.following.some(id=>id.toString()===post.author._id.toString()) ? 'btn-danger' : 'btn-success' %>">

                        <%= currentUser.following.some(id=>id.toString()===post.author._id.toString()) ? 'Unfollow' : 'Follow' %>

                    </button>

                </form>

            <% } %>

            <div class="mb-3">
            ❤️
                <strong><%= post.likes ? post.likes.length : 0 %> </strong>  Likes
            </div>

            <div class="d-flex flex-wrap gap-2 mt-2">

                <form action="/posts/<%= post._id %>/like" method="POST">
                    <button class="btn btn-outline-danger btn-sm">❤️ Like </button>
                </form>
                <a href="/posts/<%= post._id %>/edit" class="btn btn-warning btn-sm">✏ Edit </a>
                <form action="/posts/<%= post._id %>?_method=DELETE" method="POST">
                    <button class="btn btn-danger btn-sm">🗑 Delete</button>
                </form>
            </div>

            

            <hr>

            <h5 class="fw-bold">
                💬 Comments
            </h5>

            <% post.comments.forEach(comment=>{ %>

                <div
                    class="bg-light rounded p-3 mb-2">

                    <p class="mb-1">

                        <%= comment.text %>

                    </p>

                    <button
                        type="button"
                        class="btn btn-warning btn-sm"
                        onclick="toggleEdit('<%= comment._id %>')">

                        Edit

                    </button>

                    <form
                        id="editForm-<%= comment._id %>"
                        action="/comments/<%= comment._id %>/edit"
                        method="POST"
                        style="display:none;"
                        class="mt-2">

                        <input
                            type="text"
                            name="text"
                            value="<%= comment.text %>"
                            class="form-control mb-2">

                        <button
                            class="btn btn-success btn-sm">

                            Save

                        </button>

                    </form>

                    <% if(comment.author &&
                    comment.author.toString() ===
                    currentUserId.toString()){ %>

                        <form
                            action="/comments/<%= comment._id %>/delete"
                            method="POST"
                            style="display:inline;">

                            <button
                                class="btn btn-danger btn-sm mt-2">

                                Delete

                            </button>

                        </form>

                    <% } %>

                </div>

            <% }) %>

            <form
                action="/posts/<%= post._id %>/comments"
                method="POST"
                class="mt-3">

                <input
                    type="text"
                    name="text"
                    class="form-control mb-2"
                    placeholder="Write a comment...">

                <button
                    class="btn btn-primary">

                    Add Comment

                </button>

            </form>

        </div>

    </div>

<% }) %>
```

</body>

</html>
