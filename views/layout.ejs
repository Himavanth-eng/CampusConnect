<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta
    name="viewport"
    content="width=device-width, initial-scale=1.0">

<title>CampusConnect</title>

<link
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
rel="stylesheet">

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

<style>

body{
    background:
    linear-gradient(
        135deg,
        #e0f2fe 0%,
        #dbeafe 25%,
        #f5f3ff 50%,
        #ecfeff 75%,
        #ffffff 100%
    );

    background-attachment: fixed;
    min-height:100vh;
}

/* Floating Background Effects */

.blob{
    position:fixed;
    border-radius:50%;
    filter:blur(100px);
    z-index:-1;
}

.blob1{
    width:300px;
    height:300px;
    background:#60a5fa;
    top:10%;
    left:5%;
}

.blob2{
    width:350px;
    height:350px;
    background:#818cf8;
    top:50%;
    right:5%;
}

.blob3{
    width:250px;
    height:250px;
    background:#22d3ee;
    bottom:5%;
    left:40%;
}

/* Navbar */

.navbar{
    background:rgba(15,23,42,0.9);
    backdrop-filter:blur(20px);
    box-shadow:0 8px 32px rgba(0,0,0,0.15);
}

.navbar-brand{
    color:white !important;
    font-size:1.4rem;
    font-weight:700;
}

.navbar-brand img{
    border-radius:50%;
    object-fit:cover;
}

/* Main Container */

.main-container{
    min-height:85vh;
}

/* Cards */

.card{
    background:rgba(255,255,255,0.85);
    backdrop-filter:blur(15px);
    border:none;
    border-radius:20px;
    box-shadow:0 8px 32px rgba(31,38,135,0.15);
}

/* Buttons */

.btn{
    border-radius:10px;
}

/* Footer */

.footer{
    background:rgba(15,23,42,0.9);
    color:white;
    text-align:center;
    padding:20px;
    margin-top:50px;
}

.footer small{
    color:#cbd5e1;
}
.form-control{
    border-radius:12px;
    padding:12px;
}

.form-control:focus{
    box-shadow:0 0 15px rgba(59,130,246,0.3);
    border-color:#3b82f6;
}

.card{
    transition:0.3s;
}

.card:hover{
    transform:translateY(-5px);
}
.post-card{
    border:none;
    border-radius:20px;
    overflow:hidden;
    transition:0.3s;
}

.post-card:hover{
    transform:translateY(-4px);
}

.avatar{
    width:55px;
    height:55px;
    border-radius:50%;
    background:#2563eb;
    color:white;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:22px;
    font-weight:bold;
}

.post-image{
    border-radius:20px;
    max-height:450px;
    object-fit:cover;
    width:100%;
    display: block;
    margin: auto;
}

.comment-box{
    background:#f8fafc;
    border-radius:12px;
    padding:12px;
    margin-bottom:10px;
}
</style>

</head>

<body>

<!-- Background Effects -->

<div class="blob blob1"></div>
<div class="blob blob2"></div>
<div class="blob blob3"></div>

<!-- Navbar -->

<nav class="navbar navbar-expand-lg navbar-dark sticky-top">

<div class="container">

<a class="navbar-brand d-flex align-items-center" href="/posts">

<img
src="/images/clogo.png"
alt="CampusConnect"
width="50"
height="50"
class="me-2">

<span>CampusConnect</span>

</a>

<button
class="navbar-toggler"
type="button"
data-bs-toggle="collapse"
data-bs-target="#navbarNav">

<span class="navbar-toggler-icon"></span>

</button>

<div
class="collapse navbar-collapse"
id="navbarNav">

<div class="navbar-nav ms-auto gap-2">

<a href="/posts" class="btn btn-light">
<i class="fa-solid fa-house"></i> Posts
</a>

<a href="/posts/new" class="btn btn-success">
<i class="fa-solid fa-plus"></i> New Post
</a>

<a href="/profile" class="btn btn-primary">
<i class="fa-solid fa-user"></i> Profile
</a>

<a href="/my-posts" class="btn btn-outline-light">
<i class="fa-solid fa-file"></i> My Posts
</a>

<a href="/notifications" class="btn btn-warning">
🔔
</a>

<a href="/logout" class="btn btn-danger">
<i class="fa-solid fa-right-from-bracket"></i>
Logout
</a>

</div>

</div>

</div>

</nav>

<!-- Page Content -->

<div class="container mt-4 main-container">

<%- body %>

</div>

<!-- Footer -->

<footer class="footer">

<div>

<h5>CampusConnect</h5>

<p>
Connect • Collaborate • Grow
</p>

<small>
Created by Himavanth
</small>

</div>

</footer>

<script
src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
</script>

</body>

</html>