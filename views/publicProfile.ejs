<div class="card shadow border-0 mb-4">

<div class="card-body text-center p-5">

<div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto mb-3" style="width:100px; height:100px; font-size:40px; ">
<%= user.username.charAt(0).toUpperCase() %>
</div>
<h2><%= user.username %></h2>
<p class="text-muted"> 📧 <%= user.email %></p>
<p> 🎓 <strong>Branch:</strong> <%= user.branch || "Not Added" %> </p>

<p>

📝 <strong>Bio:</strong>

<%= user.bio || "No Bio Yet" %>

</p>

<div class="row mt-4">

<div class="col">

<div class="card bg-light">

<div class="card-body">

<h3>

<%= user.followers.length %>

</h3>

<p class="mb-0">

Followers

</p>

</div>

</div>

</div>

<div class="col">

<div class="card bg-light">

<div class="card-body">

<h3>

<%= user.following.length %>

</h3>

<p class="mb-0">

Following

</p>

</div>

</div>

</div>

</div>

<div class="mt-4">

<% if(isFollowing){ %>

<form
action="/follow/<%= user._id %>"
method="POST">

<button
class="btn btn-danger">

Unfollow

</button>

</form>

<% }else{ %>

<form
action="/follow/<%= user._id %>"
method="POST">

<button
class="btn btn-success">

Follow

</button>

</form>

<% } %>

</div>

</div>

</div>
<a href="/chat/<%= user._id %>" class="btn btn-primary mt-2"> 💬 Message </a>
<h3 class="mb-3">

📝 User Posts

</h3>

<% posts.forEach(post=>{ %>

<div class="card shadow-sm mb-3">

<div class="card-body">

<h5>

<%= post.title %>

</h5>

<p>

<%= post.content %>

</p>

<span class="badge bg-danger">

❤️ <%= post.likes.length %>

</span>

</div>

</div>

<% }) %>
