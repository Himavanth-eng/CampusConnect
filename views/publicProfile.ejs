<div class="card shadow-lg border-0 mb-4">

<div class="card-body text-center p-5">

<div
class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto mb-4"
style="
width:120px;
height:120px;
font-size:48px;
font-weight:bold;
">

<%= user.username.charAt(0).toUpperCase() %>

</div>

<h2 class="fw-bold">
<%= user.username %>
</h2>

<p class="text-muted">
📧 <%= user.email %>
</p>

<p>
🎓 <strong>Branch:</strong>
<%= user.branch || "Not Added" %>
</p>

<p>
📝 <strong>Bio:</strong>
<%= user.bio || "No Bio Yet" %>
</p>

<div class="row mt-4">

<div class="col-md-6">

<div class="card bg-primary text-white">

<div class="card-body">

<h2>
<%= user.followers.length %>
</h2>

Followers

</div>

</div>

</div>

<div class="col-md-6">

<div class="card bg-success text-white">

<div class="card-body">

<h2>
<%= user.following.length %>
</h2>

Following

</div>

</div>

</div>

</div>

<div class="mt-4">

<% if(isFollowing){ %>

<form action="/follow/<%= user._id %>" method="POST">

<button class="btn btn-danger btn-lg">
Unfollow
</button>

</form>

<% } else { %>

<form action="/follow/<%= user._id %>" method="POST">

<button class="btn btn-success btn-lg">
Follow
</button>

</form>

<% } %>

<a
href="/chat/<%= user._id %>"
class="btn btn-primary btn-lg mt-3">

💬 Message

</a>

</div>

</div>

</div>

<h3 class="mb-3 fw-bold">
📝 User Posts
</h3>

<% posts.forEach(post=>{ %>

<div class="card shadow-sm mb-3">

<div class="card-body">

<h5>
<%= post.title %>
</h5>

<p>
<%= post.content %>
</p>

<span class="badge bg-danger">
❤️ <%= post.likes.length %>
</span>

</div>

</div>

<% }) %>
