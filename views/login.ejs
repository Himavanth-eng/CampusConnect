<!DOCTYPE html>
<html>
<head>
    <title>Login</title>
</head>
<body>
    <div class="container">

<div class="row justify-content-center">

<div class="col-12 col-md-6 col-lg-4">

<div class="card shadow mt-5">

<div class="card-body">

<h2 class="text-center mb-4">
Login
</h2>
<form action="/login" method="POST">

<div class="mb-3">

<input
type="email"
name="email"
class="form-control"
placeholder="Email">

</div>

<div class="mb-3">
<input
type="password"
name="password"
class="form-control"
placeholder="Password">
</div>
<button
class="btn btn-primary">
Login
</button>
</form>

</div>

</div>

</div>

</div>
</div>

    <p class="mt-3"> Don't have an account?
    <a href="/register"> Register Here</a>
    </p>


</body>
</html>

