<div class="card shadow-lg border-0">

    <div class="card-body text-center p-5">

        <div
        class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto mb-4"
        style="
        width:120px;
        height:120px;
        font-size:48px;
        font-weight:bold;
        ">
            <%= user.username.charAt(0).toUpperCase() %>
        </div>

        <h2 class="fw-bold">
            <%= user.username %>
        </h2>

        <p class="text-muted">
            <%= user.email %>
        </p>

        <hr>

        <div class="row">

            <div class="col-md-6 mb-3">

                <div class="card bg-light">

                    <div class="card-body">

                        <h5>🎓 Branch</h5>

                        <p>
                            <%= user.branch || "Not Added Yet" %>
                        </p>

                    </div>

                </div>

            </div>

            <div class="col-md-6 mb-3">

                <div class="card bg-light">

                    <div class="card-body">

                        <h5>📝 Bio</h5>

                        <p>
                            <%= user.bio || "No Bio Yet" %>
                        </p>

                    </div>

                </div>

            </div>

        </div>

        <div class="row mt-4">

            <div class="col-md-6">

                <div class="card bg-primary text-white">

                    <div class="card-body">

                        <h2>
                            <%= followersCount %>
                        </h2>

                        Followers

                    </div>

                </div>

            </div>

            <div class="col-md-6">

                <div class="card bg-success text-white">

                    <div class="card-body">

                        <h2>
                            <%= followingCount %>
                        </h2>

                        Following

                    </div>

                </div>

            </div>

        </div>

        <a
        href="/profile/edit"
        class="btn btn-primary btn-lg mt-4">

        ✏ Edit Profile

        </a>

    </div>

</div>